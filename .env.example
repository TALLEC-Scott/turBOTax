# Turbo Tax Agent Configuration
# Copy this file to .env and fill in your values

# Required: OpenAI API key
OPENAI_API_KEY=

# Required: OpenAI-compatible API base URL
OPENAI_BASE_URL=

# Required: Model name to use
OPENAI_MODEL=

# Required: Path to Obsidian vault
OBSIDIAN_VAULT=./obsidian_db/turbo_tax
